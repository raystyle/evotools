#!/usr/bin/env bash
set -euo pipefail

EVO_HOME="${EVO_HOME:-$HOME/.evotools}"
INDEX="$EVO_HOME/index.json"
TOOLS_DIR="$EVO_HOME/tools"

err()  { jq -n --arg m "$1" '{error: $m}' >&2; exit 1; }
need() { command -v "$1" >/dev/null 2>&1 || err "missing dependency: $1"; }
today() { date +%F; }

init_check() {
  [ -d "$EVO_HOME/.git" ] || err "evotools repo not found at $EVO_HOME"
  [ -f "$INDEX" ] || printf '{"version": 1, "tools": []}\n' > "$INDEX"
}

find_tool() { jq -e --arg n "$1" '.tools[] | select(.name == $n)' "$INDEX" >/dev/null 2>&1; }

git_sync() { # commit-msg；提交并尽力 push
  git -C "$EVO_HOME" add -A
  git -C "$EVO_HOME" diff --cached --quiet && return 0
  git -C "$EVO_HOME" commit -q -m "$1"
  local branch; branch=$(git -C "$EVO_HOME" symbolic-ref --short HEAD)
  git -C "$EVO_HOME" push -q origin "$branch" 2>/dev/null \
    || printf '{"warning": "push failed, run evo sync later"}\n' >&2
}

add_index() { # name file lang desc deps(csv) tags(csv)
  local tmp; tmp=$(mktemp)
  jq --arg n "$1" --arg f "$2" --arg l "$3" --arg d "$4" \
     --arg deps "${5:-}" --arg tags "${6:-}" --arg today "$(today)" '
    .tools += [{
      name: $n, file: $f, lang: $l, description: $d, usage: "",
      deps: ($deps | split(",") | map(select(length > 0))),
      tags: ($tags | split(",") | map(select(length > 0))),
      created: $today, updated: $today
    }]' "$INDEX" > "$tmp" && mv "$tmp" "$INDEX"
}

cmd_new() {
  local name="" lang="" desc=""
  while [ $# -gt 0 ]; do case "$1" in
    --lang) [ $# -ge 2 ] || err "flag $1 requires a value"; lang="$2"; shift 2;;
    --desc) [ $# -ge 2 ] || err "flag $1 requires a value"; desc="$2"; shift 2;;
    -*) err "unknown flag: $1";;
    *) name="$1"; shift;;
  esac; done
  [ -n "$name" ] && [ -n "$lang" ] && [ -n "$desc" ] \
    || err 'usage: evo new <name> --lang py|ts --desc "..."'
  [[ "$name" =~ ^[a-z0-9]+(-[a-z0-9]+)*$ ]] || err "name must be kebab-case"
  local ext
  case "$lang" in
    py|python) lang=python; ext=py;;
    ts|bun)    lang=bun;    ext=ts;;
    *) err "lang must be py or ts";;
  esac
  find_tool "$name" && err "tool exists: $name (see: evo show $name)"
  local file="$TOOLS_DIR/$name.$ext"
  [ -e "$file" ] && err "file exists: $file"
  mkdir -p "$TOOLS_DIR"
  if [ "$ext" = py ]; then
    cat > "$file" <<EOF
#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = []
# ///
# task: $desc
# step: 1. implement
EOF
  else
    cat > "$file" <<EOF
#!/usr/bin/env bun
// task: $desc
// step: 1. implement
EOF
  fi
  chmod +x "$file"
  add_index "$name" "tools/$name.$ext" "$lang" "$desc" "" ""
  git_sync "evo: new tool $name"
  jq --arg n "$name" '.tools[] | select(.name == $n)' "$INDEX"
}

cmd_register() {
  local file="" desc="" tags="" update=0
  while [ $# -gt 0 ]; do case "$1" in
    --desc) [ $# -ge 2 ] || err "flag $1 requires a value"; desc="$2"; shift 2;;
    --tags) [ $# -ge 2 ] || err "flag $1 requires a value"; tags="$2"; shift 2;;
    --update) update=1; shift;;
    -*) err "unknown flag: $1";;
    *) file="$1"; shift;;
  esac; done
  [ -n "$file" ] || err 'usage: evo register <file> --desc "..." [--tags a,b] [--update]'
  [ -f "$EVO_HOME/$file" ] || err "file not found: $EVO_HOME/$file"
  local base ext name lang
  base=$(basename "$file"); ext="${base##*.}"; name="${base%.*}"
  [[ "$name" =~ ^[a-z0-9]+(-[a-z0-9]+)*$ ]] || err "name must be kebab-case"
  case "$ext" in
    py) lang=python;;
    ts) lang=bun;;
    *) err "unsupported extension: $ext";;
  esac
  if find_tool "$name"; then
    [ "$update" = 1 ] || err "tool exists: $name (use --update to refresh)"
    local tmp; tmp=$(mktemp)
    jq --arg n "$name" --arg d "$desc" --arg tags "$tags" --arg today "$(today)" '
      .tools = [.tools[] | if .name == $n then
        . + { description: (if $d == "" then .description else $d end),
              tags: (if $tags == "" then .tags else ($tags | split(",") | map(select(length > 0))) end),
              updated: $today }
      else . end]' "$INDEX" > "$tmp" && mv "$tmp" "$INDEX"
  else
    [ -n "$desc" ] || err "new tool requires --desc"
    add_index "$name" "$file" "$lang" "$desc" "" "$tags"
  fi
  git_sync "evo: register $name"
  jq --arg n "$name" '.tools[] | select(.name == $n)' "$INDEX"
}

cmd_search() {
  local q="${1:-}"
  [ -n "$q" ] || err "usage: evo search <keyword>"
  jq -r --arg q "$q" '.tools[]
    | select(((.name + " " + .description + " " + (.tags | join(" "))) | ascii_downcase)
             | contains($q | ascii_downcase))
    | "\(.name)\t\(.lang)\t\(.description)"' "$INDEX"
}

cmd_list() {
  local lang=""
  while [ $# -gt 0 ]; do case "$1" in
    --lang) [ $# -ge 2 ] || err "flag $1 requires a value"; lang="$2"; shift 2;;
    *) err "unknown flag: $1";;
  esac; done
  case "$lang" in py) lang=python;; ts) lang=bun;; esac
  jq -r --arg l "$lang" '.tools[] | select($l == "" or .lang == $l)
    | "\(.name)\t\(.lang)\t\(.description)"' "$INDEX"
}

cmd_show() {
  local name="${1:-}"
  [ -n "$name" ] || err "usage: evo show <name>"
  jq -e --arg n "$name" '.tools[] | select(.name == $n)' "$INDEX" \
    || err "tool not found: $name"
}

cmd_run() {
  local name="${1:-}"
  [ -n "$name" ] || err "usage: evo run <name> [-- args...]"
  shift
  [ "${1:-}" = "--" ] && shift
  local file lang
  file=$(jq -r --arg n "$name" '.tools[] | select(.name == $n) | .file' "$INDEX")
  [ -n "$file" ] || err "tool not found: $name"
  lang=$(jq -r --arg n "$name" '.tools[] | select(.name == $n) | .lang' "$INDEX")
  if [ "$lang" = python ]; then
    need uv
    exec uv run -q "$EVO_HOME/$file" "$@"
  else
    need bun
    exec bun --silent run "$EVO_HOME/$file" "$@"
  fi
}

cmd_sync() {
  local branch; branch=$(git -C "$EVO_HOME" symbolic-ref --short HEAD)
  git -C "$EVO_HOME" pull --rebase -q origin "$branch"
  git -C "$EVO_HOME" push -q origin "$branch"
  echo '{"status": "synced"}'
}

main() {
  need jq; need git
  local cmd="${1:-}"
  [ $# -gt 0 ] && shift
  case "$cmd" in
    new) init_check; cmd_new "$@";;
    register) init_check; cmd_register "$@";;
    search) init_check; cmd_search "$@";;
    list) init_check; cmd_list "$@";;
    show) init_check; cmd_show "$@";;
    run) init_check; cmd_run "$@";;
    sync) init_check; cmd_sync "$@";;
    *) printf 'usage: evo <new|register|search|list|show|run|sync>\n';;
  esac
}
main "$@"
